{
  "name": "calsnap-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:integration": "firebase emulators:exec --only firestore,auth --project demo-calsnap 'vitest run tests/integration'",
    "emulators": "firebase emulators:start --project demo-calsnap"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.12",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.6.0",
    "jose": "^6.1.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
