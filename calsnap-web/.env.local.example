NEXT_PUBLIC_FIREBASE_API_KEY=
# Optional fallback when no browser host is available. On localhost, auth uses this
# domain (not localhost:3000) because Firebase auth helpers require HTTPS.
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set true for local Auth + Firestore emulators (see pnpm emulators).
# Never set true on Vercel — production and preview must use cloud Firebase.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Server-only — required for session cookies in production; optional with emulators
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Server-only — required for W04 analyze route (meal scanner)
GEMINI_API_KEY=
